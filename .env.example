NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# For server-only tasks later (jobs, webhooks, admin operations)
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated admin emails allowed to access /admin
ADMIN_EMAILS=

# Local development only: allow authenticated non-admin-email users into /admin
ADMIN_DEV_BYPASS=false

# SAM.gov contract data APIs (both require a SAM.gov API key)
SAM_GOV_OPPORTUNITIES_API_URL=https://api.sam.gov/opportunities/v2/search
SAM_GOV_CONTRACT_AWARDS_API_URL=https://api.sam.gov/contract-awards/v1/search
SAM_GOV_API_KEY=
